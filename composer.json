{
    "name": "trehinos/thor",
    "description": "Thor PHP framework witch provides HTTP, MySQL and other tools",
    "minimum-stability": "stable",
    "version": "0.2-dev",
    "license": "proprietary",
    "authors": [
        {
            "name": "Sébastien GELDREICH",
            "email": "trehinos@gmail.com"
        }
    ],
    "config": {
        "vendor-dir": "vendors/",
        "bin-dir": "bin/"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/src/",
            "Thor\\": "thor/"
        }
    },
    "require": {
        "php": "^7.4",
        "ext-pdo": "*",
        "symfony/yaml": "5.*",
        "symfony/var-dumper": "5.*",
        "twig/twig": "3.*"
    }
}
