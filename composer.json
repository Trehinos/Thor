{
    "name": "trehinos/thor",
    "description": "Thor PHP framework witch provides HTTP, MySQL and other tools",
    "minimum-stability": "stable",
    "version": "0.2-dev",
    "license": "proprietary",
    "authors": [
        {
            "name": "Sébastien GELDREICH",
            "email": "trehinos@gmail.com"
        }
    ],
    "config": {
        "vendor-dir": "engine/vendors/php/",
        "bin-dir": "bin/"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/src/",
            "Thor\\": "engine/php/",
            "Packages\\": "ems/packages/",
            "Plugins\\": "ems/plugins/",
            "Themes\\": "ems/themes/",
            "Ems\\": "ems/core/"
        }
    },
    "require": {
        "php": "^7.4",
        "ext-pdo": "*",
        "symfony/yaml": "5.*",
        "symfony/var-dumper": "5.*",
        "twig/twig": "3.*"
    }
}
