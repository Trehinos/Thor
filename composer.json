{
    "name": "trehinos/thor",
    "description": "Thor PHP framework witch provides HTTP/CLI modules, Pdo smart encapsulation and other tools",
    "minimum-stability": "stable",
    "version": "0.3-dev",
    "license": "MIT - (c) 2020-2021 Sébastien GELDREICH",
    "authors": [
        {
            "name": "Sébastien GELDREICH",
            "email": "trehinos@gmail.com"
        }
    ],
    "config": {
        "vendor-dir": "vendors/",
        "bin-dir": "bin/"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/src/",
            "Thor\\": "thor/"
        }
    },
    "require": {
        "php": "^8.0",
        "ext-pdo": "*",
        "symfony/yaml": "5.*",
        "symfony/var-dumper": "5.*",
        "twig/twig": "3.*",
        "ext-pcntl": "*"
    }
}
