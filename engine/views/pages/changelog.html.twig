{% extends "thor.html.twig" %}

{% block head_title %}{{ _.index.title }} - Thor{% endblock %}

{% block titlebar %}{{ icon('code-branch', 'fas', true)|raw }} {{ _.changelog.title }}{% endblock %}

{% block head_css %}
    {{ parent() }}
    <style>
        #versions > .card {
            min-width: 240px;
            margin: 0.4em;
        }
    </style>
{% endblock %}

{% block page %}
    <div id="versions" class="d-flex flex-wrap">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">
                    {{ _.changelog.legend }}
                </h5>
                <div class="card-text">
                    <ul class="fa-ul">
                        <li>
                            <span class="fa-li" style="color: #07b">{{ icon('plus-square')|raw }}</span>
                            Added
                        </li>
                        <li>
                            <span class="fa-li" style="color: #0b7">{{ icon('sync')|raw }}</span>
                            Modified
                        </li>
                        <li>
                            <span class="fa-li" style="color: #a40">{{ icon('bug')|raw }}</span>
                            Bug fixed
                        </li>
                        <li>
                            <span class="fa-li" style="color: #96f">{{ icon('palette')|raw }}</span>
                            Style
                        </li>
                        <li>
                            <span class="fa-li" style="color: #c00">{{ icon('minus-square')|raw }}</span>
                            Removed
                        </li>
                        <li>
                            <span class="fa-li" style="color: #888">{{ icon('sticky-note')|raw }}</span>
                            Notes
                        </li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">
                    Version 0.1 <small class="text-muted">in work...</small>
                </h5>
                <div class="card-text">
                    <ul class="fa-ul">
                        <li>
                            <span class="fa-li" style="color: #07b">{{ icon('plus-square')|raw }}</span>
                            Framework
                            <ul>
                                <li>Menu system</li>
                                <li>HTTP kernel, router, Request and Response cycle, controllers</li>
                                <li>Twig and Thor PdoHandler</li>
                                <li>Debug utilities (logger)</li>
                            </ul>
                        </li>
                        <li>
                            <span class="fa-li" style="color: #07b">{{ icon('plus-square')|raw }}</span>
                            Added index page (route list and tests)
                        </li>
                        <li>
                            <span class="fa-li" style="color: #07b">{{ icon('plus-square')|raw }}</span>
                            Added users interface
                            <ul>
                                <li>Add and edit user forms</li>
                            </ul>
                        </li>
                        <li>
                            <span class="fa-li" style="color: #07b">{{ icon('plus-square')|raw }}</span>
                            Changelog page
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
