{% extends "thor.html.twig" %}

{% block head_title %}Index - Thor{% endblock %}

{% block titlebar %}{{ icon('home')|raw }} Index{% endblock %}

{% block page %}
    <h2>{{ icon('search', 'fas', true)|raw }} Recherche</h2>
    <div class="form-group">
        <label for="search">Rechercher (nom de route, path)</label>
        <input type="text" id="search" class="form-control">
    </div>
    <hr>
    <h2>{{ icon('list', 'fas', true)|raw }} Index des routes</h2>
    <ul>
        {% for routeName, route in routes %}
            <li class="align-text-top mb-4" id="route-{{ routeName }}">
                <strong>Route <span class="route-name">{{ routeName }}</span></strong> :
                <div class="badge badge-primary">
                    {{ route.controllerClass|classname }}::
                </div>
                <div class="badge badge-info">
                    {{ route.controllerMethod }}()
                </div>
                {% for pName, pInfos in route.parameters %}
                    <div class="badge badge-success">
                        ${{ pName }} : {{ pInfos.regex ?? '.*' }}
                    </div>
                {% endfor %}
                <div class="border bg-light p-2" style="min-height: 48px;">
                    {% for pName, pInfos in route.parameters %}
                        <div class="form-group d-inline-block align-text-top">
                            <label for="route-{{ routeName }}-{{ pName }}">{{ pName }}</label>
                            <input type="text" id="route-{{ routeName }}-{{ pName }}" class="param form-control" value="" data-param-name="{{ pName }}">
                        </div>
                    {% endfor %}
                    <button class="btn btn-primary float-right"
                            onclick="generateUrl('{{ routeName }}')"
                    >
                        {{ icon('play')|raw }}
                    </button>
                    <br>
                    <hr>
                    <div class="badge badge-secondary">
                        {{ route.method }}
                    </div>
                    {{ route.path }}
                </div>
            </li>
        {% endfor %}
    </ul>
{% endblock %}

{% block body_js %}
    {{ parent() }}
    <script>

        function generateUrl(routeName) {
            let $params = $("#route-" + routeName + " input.param");

            let data = {routeName};

            if ($params.length > 1) {
                $params.each((index, element) => {
                    let $element = $(element);
                    data["param-" + $element.data("param-name")] = $element.val();
                });
            } else {
                data["param-" + $params.data("param-name")] = $params.val();
            }

            $.get("{{ url("generate-url") }}", data, (response) => {
                window.location.href = response;
            });

        }

        $(() => {

        });

    </script>
{% endblock %}
