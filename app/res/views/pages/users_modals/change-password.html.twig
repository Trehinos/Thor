{% extends "modal.html.twig" %}

{% block modal_title %}{{ _.users.edit_user }}{% endblock %}

{% block modal_body %}
    <form id="form-password" action="{{ url('users-change-password-action', {'public_id': user.publicId}) }}"
          method="POST">
        <div class="form-group">
            <label for="password">Nouveau mot de passe</label>
            <input type="password" name="password" id="password" value="" class="form-control">
            <em>16 caractères minimum</em>
        </div>
        <div class="form-group">
            <label for="confirm-password">Confirmer</label>
            <input type="password" name="confirm-password" id="confirm-password" value="" class="form-control">
        </div>
    </form>
{% endblock %}

{% block modal_footer %}
    <button form="form-password" type="submit" class="btn btn-primary">
        Changer de mot de passe
    </button>
{% endblock %}
